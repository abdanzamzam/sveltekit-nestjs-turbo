{
  "name": "sveltekit-nestjs-turbo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "prettier": "^3.3.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
